    def identify_significant_eqtls(self, p_values: np.ndarray, 
                                 effect_sizes: np.ndarray,
                                 fdr_threshold: float = 0.05) -> pd.DataFrame:
        Args:
            p_values:
            effect_sizes: 
            fdr_threshold: FDR
            
        Returns:
        self.logger.info("eQTL...")

        from statsmodels.stats.multitest import fdrcorrection
        
        flat_pvals = p_values.flatten()
        _, fdr_corrected = fdrcorrection(flat_pvals, alpha=fdr_threshold)
        
        significant_mask = fdr_corrected.reshape(p_values.shape)
        sig_indices = np.where(significant_mask)
        
        results = []
        for snp_idx, gene_idx in zip(*sig_indices):
            results.append({
                'snp_index': snp_idx,
                'gene_index': gene_idx,
                'p_value': p_values[snp_idx, gene_idx],
                'effect_size': effect_sizes[snp_idx, gene_idx],
                'fdr_adjusted': fdr_corrected[snp_idx * p_values.shape[1] + gene_idx]
            })
        
        results_df = pd.DataFrame(results)
        
        self.logger.info(f" {len(results_df)} eQTL (FDR < {fdr_threshold})")
        
        return results_df
    
    def build_genotype_expression_network(self, eqtl_results: pd.DataFrame,
                                        snp_ids: List[str],
                                        gene_ids: List[str]) -> Dict:

        Args:
            eqtl_results:
            snp_ids: SNP ID
            gene_ids: 
            
        Returns:
        
        self.logger.info("Net...")
        
        network = {
            'nodes': [],
            'edges': [],
            'adjacency_matrix': None
        }
    
        for snp_id in snp_ids:
            network['nodes'].append({
                'id': snp_id,
                'type': 'snp',
                'degree': 0
            })
        
        for gene_id in gene_ids:
            network['nodes'].append({
                'id': gene_id,
                'type': 'gene',
                'degree': 0
            })
     
        edges = []
        for _, row in eqtl_results.iterrows():
            snp_id = snp_ids[int(row['snp_index'])]
            gene_id = gene_ids[int(row['gene_index'])]
            
            edge = {
                'source': snp_id,
                'target': gene_id,
                'weight': row['effect_size'],
                'p_value': row['p_value']
            }
            edges.append(edge)
          
            for node in network['nodes']:
                if node['id'] == snp_id or node['id'] == gene_id:
                    node['degree'] += 1
        
        network['edges'] = edges
      
        n_total = len(snp_ids) + len(gene_ids)
        adj_matrix = np.zeros((n_total, n_total))
        
        for edge in edges:
            src_idx = snp_ids.index(edge['source']) if edge['source'] in snp_ids else len(snp_ids) + gene_ids.index(edge['source'])
            tgt_idx = snp_ids.index(edge['target']) if edge['target'] in snp_ids else len(snp_ids) + gene_ids.index(edge['target'])
            adj_matrix[src_idx, tgt_idx] = edge['weight']
            adj_matrix[tgt_idx, src_idx] = edge['weight']
        
        network['adjacency_matrix'] = adj_matrix
        
        self.logger.info(f" ")
        
        return network
