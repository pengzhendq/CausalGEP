            filtered_seqs: 
            gc_content: 
        """
        self.logger.info("...")
        
        if len(sequences) == 0:
            return np.array([]), 0.0

        def calculate_gc(seq):
            if isinstance(seq, str):
                gc_count = seq.count('G') + seq.count('C')
                return gc_count / len(seq) * 100
            return 0.0
        
        gc_contents = np.array([calculate_gc(seq) for seq in sequences])
 
        gc_mask = (gc_contents >= gc_range[0]) & (gc_contents <= gc_range[1])
        filtered_seqs = sequences[gc_mask]
        mean_gc = np.mean(gc_contents[gc_mask]) if np.any(gc_mask) else 0.0
        
        self.logger.info(f"")
        
        return filtered_seqs, mean_gc
    
